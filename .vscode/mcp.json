{
  "servers": {
    "atlassian-jira": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@aashari/mcp-server-atlassian-jira"],
      "env": {
        "ATLASSIAN_SITE_NAME": "mrge",
        "ATLASSIAN_USER_EMAIL": "${env:ATLASSIAN_EMAIL}",
        "ATLASSIAN_API_TOKEN": "${env:ATLASSIAN_API_TOKEN}"
      }
    },
    "atlassian-confluence": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@aashari/mcp-server-atlassian-confluence"],
      "env": {
        "ATLASSIAN_SITE_NAME": "mrge",
        "ATLASSIAN_USER_EMAIL": "${env:ATLASSIAN_EMAIL}",
        "ATLASSIAN_API_TOKEN": "${env:ATLASSIAN_API_TOKEN}"
      }
    },
    "github-local": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${env:MRGE_GITHUB_PERSONAL_ACCESS_TOKEN}"
      }
    },
    "databricks": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@squadbase/mcp-databricks"],
      "env": {
        "DATABRICKS_HOST": "${env:HOST_NAME}",
        "DATABRICKS_TOKEN": "${env:DATABRICKS_TOKEN}",
        "DATABRICKS_HTTP_PATH": "${env:HTTP_PATH}"
      }
    },
    "tableau": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@tableau/mcp-server@latest"],
      "env": {
        "SERVER": "https://dub01.online.tableau.com",
        "SITE_NAME": "mrge",
        "PAT_NAME": "${env:MRGE_TABLEAU_PAT_NAME}",
        "PAT_VALUE": "${env:MRGE_TABLEAU_PAT_VALUE}"
      }
    }
  }
}
